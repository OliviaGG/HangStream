# HangStream example environment variables
# Copy this to .env and fill values before running the server

PORT=8080
NODE_ENV=development

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Owner login callback
GOOGLE_OWNER_REDIRECT_URI=http://localhost:8080/oauth/google/callback
# Viewer sign-in callback
GOOGLE_VIEWER_REDIRECT_URI=http://localhost:8080/auth/google/callback

# Optional: Spotify (if you will enable music features)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8080/oauth/spotify/callback

# Optional: TikTok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:8080/oauth/callback

# Encryption key for token storage (recommended in production)
TOKEN_ENCRYPTION_KEY=replace-with-strong-random-string

# Other
NODE_TLS_REJECT_UNAUTHORIZED=0
